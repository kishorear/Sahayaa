# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Qdrant Configuration (Local Docker Instance)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY is not needed for local instance

# Service URLs (for local development)
DATA_SERVICE_URL=http://localhost:8000
AGENT_SERVICE_URL=http://localhost:8001

# Service Ports
DATA_SERVICE_PORT=8000
AGENT_SERVICE_PORT=8001

# Environment
NODE_ENV=development

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Vector Storage Configuration
VECTOR_DIMENSION=384
VECTOR_COLLECTION_NAME=instruction_texts

# Agent Configuration
MAX_RESOLUTION_STEPS=10
DEFAULT_CONFIDENCE_THRESHOLD=0.7
SEARCH_SIMILARITY_THRESHOLD=0.8

# Performance Configuration
MAX_VECTOR_COUNT_BEFORE_SHARD=1000000
QDRANT_TIMEOUT_MS=30000
LLM_TIMEOUT_MS=45000