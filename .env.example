# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Qdrant Configuration (Local Docker Instance)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY is not needed for local instance

# Service URLs (for local development)
DATA_SERVICE_URL=http://localhost:8000
AGENT_SERVICE_URL=http://localhost:8001

# Service Ports
DATA_SERVICE_PORT=8000
AGENT_SERVICE_PORT=8001

# Environment
NODE_ENV=development
# Set to 'production' to enable production-mode behaviour in server/auth, db, and storage
SAHAYAA_ENVIRONMENT=development

# Sahayaa deployment domain(s) — used for OAuth callback URLs (comma-separated)
SAHAYAA_DOMAINS=your-app.sahayaa.ai

# Dev/staging domain — used by widget generators to substitute API URLs at runtime
SAHAYAA_DEV_DOMAIN=

# Resend connector credentials (replaces Replit-specific REPL_IDENTITY / WEB_REPL_RENEWAL)
SAHAYAA_CONNECTORS_HOSTNAME=
SAHAYAA_APP_TOKEN=
SAHAYAA_DEPLOYMENT_TOKEN=

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Vector Storage Configuration
VECTOR_DIMENSION=384
VECTOR_COLLECTION_NAME=instruction_texts

# Agent Configuration
MAX_RESOLUTION_STEPS=10
DEFAULT_CONFIDENCE_THRESHOLD=0.7
SEARCH_SIMILARITY_THRESHOLD=0.8

# Performance Configuration
MAX_VECTOR_COUNT_BEFORE_SHARD=1000000
QDRANT_TIMEOUT_MS=30000
LLM_TIMEOUT_MS=45000